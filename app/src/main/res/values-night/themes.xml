<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night-sky theme -->
    <style name="Theme.Muazzin" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/sky_900</item>
        <item name="colorOnPrimary">@color/foreground_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/foreground_primary</item>
        <item name="colorAccent">@color/secondary</item>

        <item name="android:windowBackground">@color/background_app</item>
        <item name="colorSurface">@color/background_app</item>
        <item name="colorOnSurface">@color/foreground_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="buttonBarButtonStyle">@style/Widget.Muazzin.Button.TextButton</item>
    </style>

    <style name="ThemeOverlay.Muazzin.Toolbar" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar" />

    <style name="Theme.Muazzin.Dialog" parent="Theme.MaterialComponents.Dialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="colorSurface">@color/background_elevated</item>
        <item name="colorOnSurface">@color/foreground_primary</item>
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="buttonBarButtonStyle">@style/Widget.Muazzin.Button.TextButton</item>
    </style>

    <style name="Widget.Muazzin.Button.TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/secondary</item>
        <item name="iconTint">@color/secondary</item>
    </style>
</resources>
