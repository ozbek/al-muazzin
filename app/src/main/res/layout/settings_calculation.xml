<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/label_latitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:labelFor="@+id/latitude"
            android:text="@string/latitude"
            app:layout_constraintBottom_toBottomOf="@id/latitude"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/latitude"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:autofillHints="none"
            android:inputType="numberSigned|numberDecimal"
            android:singleLine="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/labels_barrier"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/label_longitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:labelFor="@+id/longitude"
            android:text="@string/longitude"
            app:layout_constraintBottom_toBottomOf="@id/longitude"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/longitude" />

        <EditText
            android:id="@+id/longitude"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:autofillHints="none"
            android:inputType="numberSigned|numberDecimal"
            android:singleLine="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/labels_barrier"
            app:layout_constraintTop_toBottomOf="@id/latitude" />

        <Button
            android:id="@+id/lookup_gps"
            style="?attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:drawableStart="@drawable/ic_my_location"
            android:drawablePadding="8dp"
            android:drawableTint="?attr/colorAccent"
            android:text="@string/lookup_gps"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/longitude" />

        <TextView
            android:id="@+id/label_calculation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calculation"
            app:layout_constraintBottom_toBottomOf="@id/calculation_methods"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/calculation_methods" />

        <Spinner
            android:id="@+id/calculation_methods"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:drawSelectorOnTop="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/labels_barrier"
            app:layout_constraintTop_toBottomOf="@id/lookup_gps" />

        <TextView
            android:id="@+id/label_offset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:labelFor="@+id/offset_minutes"
            android:text="@string/offset"
            app:layout_constraintBottom_toBottomOf="@id/offset_minutes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/offset_minutes" />

        <EditText
            android:id="@+id/offset_minutes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:autofillHints="none"
            android:gravity="center"
            android:inputType="numberSigned"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/labels_barrier"
            app:layout_constraintTop_toBottomOf="@id/calculation_methods" />

        <Button
            android:id="@+id/reset_settings"
            style="?attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/reset"
            app:layout_constraintEnd_toStartOf="@id/save_settings"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/offset_minutes" />

        <Button
            android:id="@+id/save_settings"
            style="?attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/save"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/reset_settings"
            app:layout_constraintTop_toBottomOf="@id/offset_minutes" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/labels_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="end"
            app:constraint_referenced_ids="label_latitude,label_longitude,label_calculation,label_offset" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
