                    android:color="#C9C9C9"
                    android:offset="0.5" />
                <item
                    android:color="#3A3A3A"
                    android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Hub -->
    <path
        android:pathData="M5.5,72 a6.5,6.5 0 1,0 13,0 a6.5,6.5 0 1,0 -13,0 Z"
        android:strokeWidth="0.6"
        android:strokeColor="#1F1F1F">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="10.05"
                android:centerY="70.05"
                android:gradientRadius="8.45"
                android:type="radial">
                <item
                    android:color="#F5F5F5"
                    android:offset="0" />
                <item
                    android:color="#9AA0A6"
                    android:offset="0.55" />
                <item
                    android:color="#3A3F45"
                    android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Hub highlight -->
    <path
        android:fillAlpha="0.7"
