<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="240"
    android:viewportHeight="240">

    <!-- Scale group to match the new compass.xml size -->
    <group
        android:translateX="120"
        android:translateY="120"
        android:scaleX="1.3"
        android:scaleY="1.3">

        <group
            android:translateX="-12"
            android:translateY="-72">

            <!-- Top half (Qibla pointer, ember-orange -> gold) -->
            <path
                android:pathData="M12,4 L19,72 L5,72 Z"
                android:strokeWidth="0.5"
                android:strokeColor="#5A1200">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:endX="24"
                        android:endY="36"
                        android:startX="0"
                        android:startY="36"
                        android:type="linear">
                        <item
                            android:color="#7A1A00"
                            android:offset="0" />
                        <item
                            android:color="#FF5A1F"
                            android:offset="0.35" />
                        <item
                            android:color="#FFC857"
                            android:offset="0.55" />
                        <item
                            android:color="#7A1A00"
                            android:offset="1" />
                    </gradient>
                </aapt:attr>
            </path>

            <!-- Bottom half (polished steel) -->
            <path
                android:pathData="M12,140 L19,72 L5,72 Z"
                android:strokeWidth="0.5"
                android:strokeColor="#1F1F1F">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:endX="24"
                        android:endY="106"
                        android:startX="0"
                        android:startY="106"
                        android:type="linear">
                        <item
                            android:color="#3A3A3A"
                            android:offset="0" />
                        <item
                            android:color="#C9C9C9"
                            android:offset="0.5" />
                        <item
                            android:color="#3A3A3A"
                            android:offset="1" />
                    </gradient>
                </aapt:attr>
            </path>

            <!-- Hub -->
            <path
                android:pathData="M12,65.5 A6.5,6.5 0 1,1 12,78.5 A6.5,6.5 0 1,1 12,65.5 Z"
                android:strokeWidth="0.6"
                android:strokeColor="#1F1F1F">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:centerX="12"
                        android:centerY="72"
                        android:gradientRadius="8.45"
                        android:type="radial">
                        <item
                            android:color="#F5F5F5"
                            android:offset="0" />
                        <item
                            android:color="#9AA0A6"
                            android:offset="0.55" />
                        <item
                            android:color="#3A3F45"
                            android:offset="1" />
                    </gradient>
                </aapt:attr>
            </path>

            <!-- Hub highlight -->
            <path
                android:fillAlpha="0.7"
                android:fillColor="#FFFFFF"
                android:pathData="M10.5,70.5 A1.5,1.5 0 1,1 10.5,73.5 A1.5,1.5 0 1,1 10.5,70.5 Z" />
        </group>
    </group>
</vector>
