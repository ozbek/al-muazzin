    android:width="24dp"
    android:height="144dp"
    android:viewportWidth="24"
    android:viewportHeight="144">

    <!-- Top half (Qibla pointer, ember-orange -> gold) -->
    <path
        android:pathData="M12,4 L19,72 L5,72 Z"
        android:strokeWidth="0.5"
        android:strokeColor="#5A1200">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="24"
                android:endY="36"
                android:startX="0"
                android:startY="36"
                android:type="linear">
                <item
                    android:color="#7A1A00"
                    android:offset="0" />
                <item
                    android:color="#FF5A1F"
                    android:offset="0.35" />
                <item
                    android:color="#FFC857"
                    android:offset="0.55" />
                <item
                    android:color="#7A1A00"
                    android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom half (polished steel) -->
    <path
        android:pathData="M12,140 L19,72 L5,72 Z"
        android:strokeWidth="0.5"
        android:strokeColor="#1F1F1F">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="24"
                android:endY="106"
                android:startX="0"
                android:startY="106"
                android:type="linear">
                <item
                    android:color="#3A3A3A"
                    android:offset="0" />
